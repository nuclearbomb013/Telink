# =============================================================================
# TechInk Backend - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# For production, use Docker secrets, Kubernetes secrets, or a cloud
# secret manager instead of plaintext .env files when possible.
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_NAME=TechInk API
APP_VERSION=1.0.0

# Environment: development | staging | production
# production mode enables: HSTS, secure cookies, strict CORS, no debug docs
ENVIRONMENT=development

# Debug mode: True for dev (enables /api/docs, verbose errors), False for prod
DEBUG=True

# ---------------------------------------------------------------------------
# Database (PostgreSQL with asyncpg)
# ---------------------------------------------------------------------------
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/techink

# Connection pool settings
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
# !! CRITICAL !! Generate a unique key for EVERY environment:
#    python -c "import secrets; print(secrets.token_urlsafe(32))"
# Without a persistent SECRET_KEY, all tokens become invalid on restart.
SECRET_KEY=change-me-to-a-random-64-char-string

# JWT algorithm (HS256 for single-service, RS256 for microservices)
ALGORITHM=HS256

# Token lifetimes (in minutes/days)
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days
REFRESH_TOKEN_EXPIRE_DAYS=30        # 30 days

# ---------------------------------------------------------------------------
# CORS Configuration
# ---------------------------------------------------------------------------
# !! PRODUCTION !! Must be an explicit list of allowed origins.
# Using ["*"] in production will cause the app to refuse startup.
# Development examples:
#   CORS_ORIGINS='["http://localhost:5173","http://127.0.0.1:5173"]'
# Production example:
#   CORS_ORIGINS='["https://techink.example.com","https://www.techink.example.com"]'
CORS_ORIGINS='["http://localhost:5173","http://127.0.0.1:5173"]'

CORS_METHODS='["GET","POST","PUT","DELETE","PATCH","OPTIONS"]'
CORS_HEADERS='["Content-Type","Authorization","X-Requested-With"]'

# ---------------------------------------------------------------------------
# Rate Limiting
# ---------------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100      # Max requests per window
RATE_LIMIT_WINDOW=60         # Window in seconds

# ---------------------------------------------------------------------------
# File Upload
# ---------------------------------------------------------------------------
MAX_UPLOAD_SIZE_MB=5
ALLOWED_UPLOAD_EXTENSIONS=jpg,jpeg,png,gif,webp

# ---------------------------------------------------------------------------
# Email (for password reset, notifications)
# ---------------------------------------------------------------------------
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@techink.example.com
# SMTP_PASSWORD=
# SMTP_FROM=noreply@techink.example.com
