# Database
# WARNING: In production, use Docker secrets or a secret manager
# instead of plaintext passwords in environment variables.
# See docker-compose.yml for secrets-based configuration.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/techink

# Database Pool Configuration
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Security
# IMPORTANT: Generate a secure key for production with:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-this-in-production-at-least-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS Configuration
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
CORS_METHODS=["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"]
CORS_HEADERS=["Content-Type", "Authorization", "X-Requested-With"]

# Environment (development, staging, production)
ENVIRONMENT=development