# TechInk Web Environment Configuration
# Copy this file to .env.local and fill in your values

# ============================================
# Application Settings
# ============================================
VITE_APP_NAME=TechInk
VITE_APP_URL=https://techink.dev
VITE_APP_DESCRIPTION=TechInk 是一个专注于技术交流的社区

# ============================================
# API Configuration
# ============================================
# Backend API URL (FastAPI)
# 开发环境使用相对路径 /api/v1（通过 Vite 代理转发）
# 生产环境使用完整 URL，如 https://api.techink.dev/api/v1
VITE_API_URL=/api/v1

# Newsletter subscription API endpoint
VITE_NEWSLETTER_API_URL=

# Contact form API endpoint
VITE_CONTACT_API_URL=

# ============================================
# Analytics (Optional)
# ============================================
# Google Analytics Measurement ID
VITE_GA_MEASUREMENT_ID=

# Umami Analytics (privacy-friendly alternative)
VITE_UMAMI_SCRIPT_URL=
VITE_UMAMI_WEBSITE_ID=

# ============================================
# Feature Flags
# ============================================
# Enable/disable newsletter subscription
VITE_FEATURE_NEWSLETTER=true

# Enable/disable search functionality
VITE_FEATURE_SEARCH=true

# Enable/disable dark mode toggle
VITE_FEATURE_DARK_MODE=false

# ============================================
# Build Configuration
# ============================================
# Enable source maps in production
VITE_SOURCE_MAP=false

# Bundle analyzer
VITE_ANALYZE_BUNDLE=false
